{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/senarzuniga/Source-of-Truth/main/agents/evaluation/validation-schema.json",
  "title": "Agent Response Validation Schema",
  "description": "Schema for validating agent responses according to Source of Truth v1.0.0 standard",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "agent_id",
    "run_id",
    "timestamp",
    "task",
    "analysis",
    "hypotheses",
    "selected_solution",
    "result",
    "iterations",
    "self_evaluation"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Unique identifier of the agent",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this execution run",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the response",
      "format": "date-time"
    },
    "task": {
      "type": "string",
      "description": "Description of the task being addressed",
      "minLength": 10
    },
    "analysis": {
      "type": "object",
      "description": "Problem analysis performed before generating hypotheses",
      "required": ["problem_understood", "constraints", "success_metrics"],
      "properties": {
        "problem_understood": {
          "type": "string",
          "description": "Summary of the problem as understood by the agent",
          "minLength": 20
        },
        "constraints": {
          "type": "array",
          "description": "List of identified constraints",
          "items": { "type": "string" }
        },
        "success_metrics": {
          "type": "array",
          "description": "Criteria to evaluate success",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "description": "List of hypotheses evaluated (minimum 3 required)",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "description", "score", "evidence", "validated"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^H[0-9]+$",
            "description": "Hypothesis identifier (e.g., H1, H2, H3)"
          },
          "description": {
            "type": "string",
            "description": "Description of the hypothesis or approach",
            "minLength": 20
          },
          "score": {
            "type": "number",
            "description": "Evaluation score from 0.0 to 1.0",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "evidence": {
            "type": "string",
            "description": "Evidence supporting or refuting this hypothesis",
            "minLength": 10
          },
          "assumptions": {
            "type": "array",
            "description": "Implicit assumptions in this hypothesis",
            "items": { "type": "string" }
          },
          "validated": {
            "type": "boolean",
            "description": "Whether this hypothesis was empirically validated"
          },
          "validation_method": {
            "type": "string",
            "description": "How the hypothesis was validated",
            "enum": ["code_execution", "tests", "simulation", "peer_review", "data_analysis", "not_validated"]
          }
        }
      }
    },
    "selected_solution": {
      "type": "object",
      "description": "The selected best solution from the evaluated hypotheses",
      "required": ["hypothesis_id", "justification", "confidence"],
      "properties": {
        "hypothesis_id": {
          "type": "string",
          "pattern": "^H[0-9]+$",
          "description": "ID of the selected hypothesis"
        },
        "justification": {
          "type": "string",
          "description": "Why this solution was selected over alternatives",
          "minLength": 30
        },
        "confidence": {
          "type": "number",
          "description": "Confidence level in the selected solution",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "result": {
      "type": "string",
      "description": "The final response or solution delivered",
      "minLength": 1
    },
    "iterations": {
      "type": "integer",
      "description": "Number of iterations performed",
      "minimum": 1,
      "maximum": 10
    },
    "self_evaluation": {
      "type": "object",
      "description": "Agent's self-assessment of the response",
      "required": ["accuracy", "limitations"],
      "properties": {
        "accuracy": {
          "type": "number",
          "description": "Self-assessed accuracy of the response",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "limitations": {
          "type": "string",
          "description": "Known limitations of this response"
        },
        "future_improvements": {
          "type": "string",
          "description": "What could be improved in the next iteration"
        },
        "requirements_met": {
          "type": "boolean",
          "description": "Whether all original requirements were met"
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata",
      "properties": {
        "standard_version": {
          "type": "string",
          "description": "Version of the Source of Truth standard used",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "autonomy_level": {
          "type": "string",
          "description": "Autonomy level at which the agent operated",
          "enum": ["L0", "L1", "L2", "L3", "L4"]
        },
        "human_approval_required": {
          "type": "boolean",
          "description": "Whether human approval was required for this action"
        },
        "human_approval_obtained": {
          "type": "boolean",
          "description": "Whether human approval was obtained (if required)"
        },
        "outcome": {
          "type": "string",
          "description": "Final outcome of the agent's task",
          "enum": ["success", "failure", "partial", "pending_approval"]
        }
      }
    }
  }
}
